# Supabase — copie este ficheiro para `.env.local` e preencha com os valores
# do seu projecto de desenvolvimento. Nunca versione `.env.local` nem cole
# estes valores em Git, no chat ou na documentação.

# URL do projecto Supabase (ex.: https://xxxxxxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Chave publicável (publishable key, formato `sb_publishable_...`).
# É segura para uso no browser. NÃO use aqui a chave secreta / service_role.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
