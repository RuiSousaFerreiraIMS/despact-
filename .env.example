# Supabase — copie este ficheiro para `.env.local` e preencha com os valores
# do seu projecto de desenvolvimento. Nunca versione `.env.local` nem cole
# estes valores em Git, no chat ou na documentação.

# URL do projecto Supabase (ex.: https://xxxxxxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Chave publicável (publishable key, formato `sb_publishable_...`).
# É segura para uso no browser. NÃO use aqui a chave secreta / service_role.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Enable Banking (sincronização bancária, D-009) — SEGREDOS DE SERVIDOR.
# Nunca usar prefixo NEXT_PUBLIC_. O Application ID vem do Control Panel;
# a chave é o ficheiro .pem descarregado no registo, codificado em base64
# numa só linha (ex.: base64 -w0 ficheiro.pem).
ENABLE_BANKING_APP_ID=
ENABLE_BANKING_PRIVATE_KEY_BASE64=

# GoCardless Bank Account Data (Open Banking, D-009) — segredos EXCLUSIVOS do
# servidor: sem prefixo NEXT_PUBLIC_, nunca chegam ao browser. Criados em
# bankaccountdata.gocardless.com → Developers → User secrets.
GOCARDLESS_SECRET_ID=
GOCARDLESS_SECRET_KEY=
